{
  "manifest_version": 3,
  "name": "ChatPTPanel",
  "version": "2.0.1",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "sidePanel", "declarativeNetRequest", "declarativeNetRequestFeedback", "tabs"],
  "host_permissions": ["https://chatgpt.com/*", "*://*.chatgpt.com/*"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "*://*.chatgpt.com/*"],
      "js": ["chatgpt-content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "description": "Access OpenAI ChatGPT in a mini window, perfect for multitasking devs to stay connected without leaving their workspace."
}
