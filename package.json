{
  "name": "chatgptpanel",
  "version": "1.0.0",
  "description": "Access OpenAI ChatGPT in a mini window, perfect for multitasking devs to stay connected without leaving their workspace.",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.0.277",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "prettier": "^3.3.3"
  },
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node --test tests/unit/*.js",
    "test:e2e": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-e2e.ps1",
    "test:e2e:canary": "cross-env PW_CFT_CANARY=1 pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-e2e.ps1",
    "codegen:e2e": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-e2e-codegen.ps1",
    "codegen:e2e:mock": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-e2e-codegen-mock.ps1",
    "release": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/release.ps1",
    "lint": "eslint .",
    "format": "prettier --check *.{js,json} src/**/*.{js,json,css,html} tests/**/*.js",
    "format:write": "prettier --write *.{js,json} src/**/*.{js,json,css,html} tests/**/*.js",
    "format:all": "prettier --write *.{js,json} src/**/*.{js,json,css,html} .github/workflows/*.{yml,yaml} devdocs/**/*.md tests/**/*.js",
    "format:write:files": "prettier --write",
    "playwright:install:chromium": "playwright install chromium"
  }
}
