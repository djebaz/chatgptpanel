{
  "srcRoot": "src",
  "distRoot": "dist",
  "manifestPath": "src/manifest.json",
  "manifestRelPath": "manifest.json",
  "appName": "ChatPTPanel",
  "allowlist": [
    "manifest.json",
    "background.js",
    "icons",
    "lib",
    "popup.html",
    "popup.js",
    "sidepanel.html",
    "rules.json"
  ],
  "excludeFolders": [
    "tests",
    "test",
    "__tests__",
    "node_modules",
    "scripts",
    "devdocs",
    "devlogs",
    "playwright-report",
    "dist",
    ".github",
    ".vscode",
    "src/tests",
    "src/test",
    "src/__tests__"
  ],
  "excludeGlobs": [
    "**/*.md",
    "**/*.txt",
    "**/*.map",
    "**/*.log",
    "lib/webcodecs/mediabunny.mjs"
  ],
  "excludeNamePatterns": [
    "\\.map$",
    "\\.bak$",
    "\\.log$",
    "\\.tmp$"
  ]
}
